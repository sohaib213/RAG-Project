# App
APP_NAME=rag-app
APP_VERSION=0.1.0

# File Upload Settings
FILE_ALLOWED_EXTENSIONS=["text/plain", "application/pdf"]
FILE_MAX_SIZE_MB=10
FILE_CHUNK_SIZE=512000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=rag-app

# LLM Provider
# Recommended: Groq (free) → https://console.groq.com
OPENAI_API_KEY=your-groq-api-key-here
OPENAI_API_BASE=https://api.groq.com/openai/v1/
GENERATE_RESPONSE_MODEL=llama-3.1-8b-instant
GENERATION_BACKEND=openai

# Embedding Model (local — no API key needed)
EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL_SIZE=384
EMBEDDING_MODEL_MAX_INPUT_LENGTH=512

# Qdrant Cloud
QDRANT_URL=https://<your-cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here

# Vector DB Settings
VECTOR_DB_PATH=qdrant_data
VECTOR_DB_DISTANCE_METRIC=Cosine

# Generation Settings
MAX_INPUT_TOKENS=1000
MAX_RESPONSE_TOKENS=1000
TEMPERATURE=0.1